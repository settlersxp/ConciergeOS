FROM python:3.12-slim

WORKDIR /app

RUN pip install requests pyyaml valkey --no-cache-dir

COPY role_sync.py .
COPY settings.py .
COPY rbac_routes.yaml .

ENV KEYCLOAK_URL=http://keycloak:8080/auth
ENV KEYCLOAK_REALM=production
ENV KEYCLOAK_ADMIN_USER=admin
ENV KEYCLOAK_ADMIN_PASSWORD=admin
ENV CADDY_ADMIN_URL=http://caddy:2019
ENV SYNC_INTERVAL=10
ENV VALKEY_URL=redis://valkey:6379/0
ENV SESSION_COOKIE_NAME=_oauth2_proxy

CMD ["python3", "-u", "/app/role_sync.py"]